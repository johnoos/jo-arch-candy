<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "Fragment Gallery" }}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="outer-wrapper">
        {% include "partials/header.html" %}

        <div class="middle-wrapper">
                {% include "partials/sidebar.html" %}

                {# This is the ONLY place content enters the shell #}
                <main id="content-panel-container">
                    {% block main %}{% endblock %}
                </main>   
        </div>

        {% include "partials/footer.html" %}

        <!-- Spinner overlay -->
        <div id="spinner" class="spinner-overlay"></div>
        <div id="menu-overlay"></div> 
    </div>    

<script type="module" src="/assets/js/controllerNavHandler.js"></script>
</body>
</html>